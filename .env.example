# =============================================================================
# Sentinel Fraud Ops — Environment Variables
# Copy to .env and fill in values before running docker-compose up
# =============================================================================

# --- Security ---
REDIS_PASSWORD=change_me_in_production
SENTINEL_API_KEY=change_me_to_a_random_api_key

# --- Operation Mode ---
# 'demo'       = uses ground truth labels for financial metrics (simulation)
# 'production' = no ground truth; financial metrics disabled
SENTINEL_MODE=demo

# --- CORS (comma-separated origins allowed to call the API) ---
ALLOWED_ORIGINS=http://localhost:8501,http://dashboard:8501

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Simulation ---
SIMULATION_RATE=2.0
